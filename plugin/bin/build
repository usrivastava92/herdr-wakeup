#!/usr/bin/env bash
# Build step (runs on `herdr plugin install`, not on `plugin link`).
# Builds the Herdr watcher binary from the plugin repo root.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "$DIR/../.." && pwd)"
cd "$repo"
if command -v cargo >/dev/null 2>&1; then
  cargo build --release
else
  echo "herdr-wakeup: cargo not found; install Rust to build, or install wakeup-herdr manually." >&2
  exit 1
fi
