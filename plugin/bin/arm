#!/usr/bin/env bash
# Action: resume normal wake/sleep behavior (undo a previous disarm).
#
# This just flips `armed: true` in the persisted config.json - it does not
# require the watcher to be running, and a running watcher picks up the
# change on its next evaluation without needing a restart or signal
# (see App::reload_armed in the Rust source, Milestone 4).
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$DIR/lib.sh"
resolve_bins
"$WAKEUP_HERDR" arm
