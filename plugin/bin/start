#!/usr/bin/env bash
# Action: start the keep-awake watcher in the background (no pane).
#
# Usage:
#   start          Unconditionally start a watcher (the manual action).
#   start --auto   Autostart path fired by the [[events]] hooks in
#                  herdr-plugin.toml. Starts a watcher only when autostart is
#                  enabled (config.json `autostart`, overridable by the
#                  HERDR_WAKEUP_AUTOSTART env var), and stays quiet and cheap
#                  when one is already running so high-frequency events like
#                  pane.focused cost almost nothing and never fail the handler.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$DIR/lib.sh"

auto=0
case "${1:-}" in
  --auto) auto=1 ;;
  "") ;;
  *) echo "usage: start [--auto]" >&2; exit 2 ;;
esac

if [ "$auto" = 1 ]; then
  # Never let an event handler fail the caller: a missing binary or disabled
  # autostart is just "nothing to do", not an error.
  resolve_bins || exit 0
else
  resolve_bins
fi

if [ "$auto" = 1 ]; then
  # Fast path: already running -> done. Keeps repeated events near-free.
  watcher_pid >/dev/null 2>&1 && exit 0
  # Gate: only autostart when the config/env decision says so.
  "$WAKEUP_HERDR" autostart-decision >/dev/null 2>&1 || exit 0
  acquire_start_lock try || exit 0
  if pid="$(watcher_pid)"; then
    exit 0
  fi
else
  acquire_start_lock wait
  if pid="$(watcher_pid)"; then
    echo "herdr-wakeup watcher already running (pid $pid)"
    exit 0
  fi
fi

log="$(logfile)"
# Detach fully so it survives this action returning. The watcher posts ☕/💤
# toasts on transitions and releases wakeup on SIGTERM/SIGHUP.
nohup "$WAKEUP_HERDR" >>"$log" 2>&1 &
pid=$!
write_pidfile "$pid" "$WAKEUP_HERDR"
disown "$pid" 2>/dev/null || true
sleep 0.2
if ! watcher_pid >/dev/null; then
  rm -f "$(pidfile)" 2>/dev/null || true
  echo "failed to start herdr-wakeup watcher; see log: $log" >&2
  exit 1
fi
echo "started herdr-wakeup watcher (pid $pid); log: $log"
